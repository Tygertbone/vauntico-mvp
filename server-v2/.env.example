# Vauntico Trust Score Backend - FREE Stack Configuration
# Copy this to .env and fill in your actual values

# Database Configuration (Neon.tech PostgreSQL Free Tier)
DATABASE_URL=postgresql://[username]:[password]@[host]/neondb?sslmode=require

# JWT Configuration (Generate random secrets for production)
JWT_SECRET=your-jwt-secret-change-in-production-32-chars-min
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production-32-chars-min
CRON_SECRET=your-cron-secret-for-github-actions

# Redis Configuration (Upstash Redis Free Tier)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# OAuth Encryption (Optional - for storing OAuth tokens securely)
OAUTH_ENCRYPTION_KEY=fallback-oauth-key-change-in-production
OAUTH_ENCRYPTION_SALT=oauthtrustscore

# Application Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Email Service (Resend.com Free Tier)
RESEND_API_KEY=re_your-resend-api-key

# Anthropic AI (Free $5 Credit)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google OAuth (for Google Analytics/YouTube)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Slack Alerting (for production monitoring)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Stripe OAuth (for Revenue Tracking)
STRIPE_CLIENT_ID=your-stripe-client-id
STRIPE_SECRET_KEY=your-stripe-secret-key

# Logging Configuration
LOG_LEVEL=info

# Additional Security (Optional)
# SESSION_SECRET=your-session-secret-for-additional-security
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# GitHub Actions Secrets (stored in GitHub repo settings)
# BACKEND_URL=https://your-render-app.onrender.com
# CRON_SECRET=(same as above CRON_SECRET)
