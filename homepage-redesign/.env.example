# Paystack Configuration
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here@o123456.ingest.sentry.io/123456

# Slack Webhook for Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Application URLs
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Paystack Server Integration (for webhook verification)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
